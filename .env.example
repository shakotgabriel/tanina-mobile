# Copy this file to .env and fill in your values
# Expo requires the EXPO_PUBLIC_ prefix for variables accessible in the app

# Your backend API base URL (no trailing slash)
# Development:  http://192.168.x.x:8080   (use your machine's LAN IP, not localhost)
# Staging:      https://api.staging.tanina.app
# Production:   https://api.tanina.app
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.100:8080
